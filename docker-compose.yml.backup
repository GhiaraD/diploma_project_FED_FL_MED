    environment:
      NODE_ID: node2
      STORAGE_ROOT: /storage
      CENTRAL_URL: http://central:8081
      FLOWER_SERVER: central:8080
      REDIS_URL: redis://node2-redis:6379/0
      DEVICE: cuda
      TZ: ${TZ:-UTC}
      # SSL/TLS Configuration
      ENABLE_SSL: "true"
      CERTIFICATES_PATH: /certificates
      # Client-side Differential Privacy Configuration
      ENABLE_DP: "false"  # Enable client-side DP (Opacus)
      DP_TARGET_EPSILON: "1.0"  # Privacy budget per round
      DP_TARGET_DELTA: "1e-5"  # Failure probability
      DP_NOISE_MULTIPLIER: "1.0"  # Noise scale
      DP_MAX_GRAD_NORM: "1.0"  # Gradient clipping threshold
      DP_MAX_EPOCHS: "10"  # Maximum epochs for privacy accounting
    volumes:
      - ./storage/node2:/storage
      - ./certificates:/certificates:ro  # Mount certificates read-only
      - /etc/localtime:/etc/localtime:ro
      - /etc/timezone:/etc/timezone:ro
    depends_on:
      - node2-redis
      - node2-api
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 1
              capabilities: [gpu]

  node2-redis:
    image: redis:7
    ports:
      - "63792:6379"

  node2-ui:
    build:
      context: ./services/node/ui
      dockerfile: Dockerfile
    environment:
      NEXT_PUBLIC_API_BASE: http://localhost:8002
    ports:
      - "3002:3000"
    depends_on:
      - node2-api

  # ===== Node 3 =====
  node3-api:
